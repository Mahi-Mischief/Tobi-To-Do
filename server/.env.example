# ==============================================
# TOBI TO-DO ENVIRONMENT CONFIGURATION
# ==============================================
# Copy this file to .env and fill in your values
# DO NOT commit .env to git
# ==============================================

# ========== ENVIRONMENT ==========
NODE_ENV=development
PORT=5000

# ========== SUPABASE DATABASE ==========
# Get these from your Supabase Dashboard:
# https://app.supabase.com → Your Project → Settings → Database → Connection Info

DB_HOST=db.trcmyrwxihgkmxnvhfqv.supabase.co
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=YOUR_SUPABASE_DATABASE_PASSWORD
DB_SSL=true

# ========== SUPABASE CONFIG ==========
SUPABASE_URL=https://trcmyrwxihgkmxnvhfqv.supabase.co
SUPABASE_ANON_KEY=sb_publishable_DKzrua89HR7XU3tcrI-mjw_317t1lsA
SUPABASE_SERVICE_KEY=YOUR_SERVICE_KEY_FROM_SETTINGS_API_TAB

# ========== JWT AUTHENTICATION ==========
# Generate a random string for production (min 32 characters)
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production_min_32_chars
JWT_EXPIRY=7d

# ========== FIREBASE (Optional, for OAuth) ==========
# Get these from Firebase Console → Project Settings → Service Accounts
FIREBASE_PROJECT_ID=tobi-to-do
FIREBASE_API_KEY=AIzaSyAYkZHimR12SSGnSKxy3lUHybSgFB5VZX0
FIREBASE_AUTH_DOMAIN=tobi-to-do.firebaseapp.com
FIREBASE_STORAGE_BUCKET=tobi-to-do.firebasestorage.app
FIREBASE_MESSAGING_SENDER_ID=730780218273
FIREBASE_APP_ID=1:730780218273:web:a58712579f85c569d9d1e0
FIREBASE_PRIVATE_KEY=your-firebase-private-key-from-service-account
FIREBASE_CLIENT_EMAIL=your-firebase-client-email-from-service-account
FIREBASE_PRIVATE_KEY_ID=your-firebase-private-key-id-from-service-account

# ========== AI SERVICES (Hugging Face - Optional) ==========
HUGGING_FACE_API_KEY=your_hugging_face_api_key
HUGGING_FACE_MODEL_ID=mistralai/Mistral-7B-Instruct-v0.1

# ========== CORS CONFIGURATION ==========
# Comma-separated list of allowed origins
CORS_ORIGIN=http://localhost:3000,http://localhost:8080,http://localhost:5000

# ==================================================================
# Database / SSL Notes
# ------------------------------------------------------------------
# Required DB environment variables (set these in your local `.env`):
# - DB_HOST     (e.g. db.trcmyrwxihgkmxnvhfqv.supabase.co)
# - DB_PORT     (usually 5432)
# - DB_NAME     (e.g. postgres)
# - DB_USER     (e.g. postgres)
# - DB_PASSWORD (your DB password)
#
# Supabase/Postgres requires SSL. Two local development options:
# 1) Use the provided certificate file and set PROD_CA_PATH to its path:
#      PROD_CA_PATH=server/prod-ca-2021.crt
#    This enforces secure SSL verification (recommended for staging/production).
#
# 2) Quick insecure fallback (development only):
#      DB_SSL_FALLBACK_ALLOW_INSECURE=true
#    This sets `rejectUnauthorized: false` and disables strict SSL verification.
#    DO NOT use this in production.
#
# Notes:
# - Ensure the values are visible to Node (your process). In PowerShell use
#     node -e "console.log(process.env.DB_PASSWORD ? 'set' : 'NOT set')"
# - If the server fails with "password authentication failed" or SSL errors,
#   double-check `DB_PASSWORD`, `DB_HOST`, `PROD_CA_PATH`, and the fallback flag.
# ==================================================================
